#!/usr/bin/env bash
# commit-msg hook — block `feat(M<N>)` commits that forget to bump
# __version__ to at least 0.<N>.0.
#
# Activate per clone:
#   git config core.hooksPath .githooks
set -euo pipefail

commit_msg_file="$1"
first_line="$(head -n 1 "$commit_msg_file")"

# Skip merge commits.
if [ -f .git/MERGE_HEAD ]; then
    exit 0
fi

# Match feat(M<N>) or feat(M<N>.<sub>) — feat type only.
if [[ ! "$first_line" =~ ^feat\(M([0-9]+)(\.[0-9]+)?\) ]]; then
    exit 0
fi

milestone_n="${BASH_REMATCH[1]}"
version_file="src/litman/__init__.py"

# Read __version__ as it will be after this commit: staged content if the file
# is in the index, else HEAD's copy.
staged_content="$(git show ":$version_file" 2>/dev/null || true)"
if [ -z "$staged_content" ]; then
    echo "commit-msg hook: cannot read $version_file from index/HEAD; skipping" >&2
    exit 0
fi

current_version="$(printf '%s\n' "$staged_content" | grep -oE '__version__[[:space:]]*=[[:space:]]*"[0-9]+\.[0-9]+\.[0-9]+"' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || true)"
if [ -z "$current_version" ]; then
    echo "commit-msg hook: could not parse __version__ from $version_file" >&2
    exit 1
fi

minor="$(printf '%s\n' "$current_version" | cut -d. -f2)"

if [ "$minor" -lt "$milestone_n" ]; then
    cat >&2 <<EOF
[X] commit-msg hook: __version__ drift detected

  Commit subject : $first_line
  Implies        : M$milestone_n -> __version__ should be >= 0.$milestone_n.0
  Currently      : __version__ = "$current_version"

  Fix:
    1. Edit src/litman/__init__.py: __version__ = "0.$milestone_n.0"
    2. git add src/litman/__init__.py
    3. Re-run your commit

  Bypass (rarely needed):
    git commit --no-verify
EOF
    exit 1
fi

exit 0
