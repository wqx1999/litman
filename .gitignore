# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual envs (none expected here — we use conda env `litman` — but ignore anyway)
.venv/
venv/
env/

# Test / lint / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# litman-bench downloaded fixture PDFs (copyrighted — fetched, never committed).
# Only the PDFs are ignored; fixtures/golden/*.json (extraction ground truth) IS tracked.
tests/bench/fixtures/pdfs/

# webUI frontend build artifacts (node toolchain output; the vendored
# vite build under src/litman/assets/webui/ IS tracked, but these are not).
frontend/node_modules/
frontend/.vite/
frontend/dist/
